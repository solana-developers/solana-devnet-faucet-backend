# Copy to .env and fill in. Only needed for native `npm start`; docker compose
# sets its own env and ignores this file.

# Port the API listens on (default: 3000)
PORT=3000

# --- Database ---
# Option A: direct Postgres connection string (local dev).
# Matches the docker-compose postgres service on host port 5433.
POSTGRES_STRING=postgres://faucet:faucet@localhost:5433/faucet

# Option B: Cloud SQL via the auth proxy (prod-like). If DB_CONNECTION_NAME is
# set, DB_USER/DB_NAME/DB_PASSWORD are used and POSTGRES_STRING is ignored.
# DB_CONNECTION_NAME=<project>:<region>:<instance>
# DB_USER=
# DB_NAME=
# DB_PASSWORD=

# --- Auth ---
# GCP project the faucet frontend's service account lives in. Used only when
# POSTGRES_STRING is unset — setting POSTGRES_STRING bypasses Google token
# validation for local dev.
PROJECT_ID=

# --- GitHub (optional) ---
# Comma-separated Personal Access Tokens with `read:user` and `public_repo`
# scopes. Multiple tokens rotate automatically on rate-limit responses.
GH_TOKENS=
